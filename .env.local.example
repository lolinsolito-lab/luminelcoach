# LuminelCoach Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===== GEMINI AI =====
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ===== AUTHENTICATION =====
# For production, you'll need a real auth provider (Firebase, Supabase, Auth0, etc.)
# VITE_AUTH_PROVIDER=firebase
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=

# ===== PAYMENT PROCESSING =====
# Stripe for subscription management
# VITE_STRIPE_PUBLIC_KEY=
# VITE_STRIPE_SECRET_KEY= (server-side only)

# ===== GOOGLE INTEGRATIONS =====
# For Calendar, Drive, Sheets integrations
# VITE_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_API_KEY=

# ===== MAKE.COM WEBHOOKS =====
# For automation workflows
# VITE_MAKE_WEBHOOK_URL=

# ===== DATABASE =====
# For production data persistence (Supabase, Firebase, MongoDB, etc.)
# VITE_DATABASE_URL=
# VITE_DATABASE_KEY=

# ===== HOSTING =====
# Base URL for production
# VITE_APP_URL=https://luminelcoach.com
